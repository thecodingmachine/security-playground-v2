{% extends 'base.html.twig' %}

{% block title %}Tableau de bord{% endblock %}

{% block body %}
<div class="space-y-6">
    <div>
        <h2 class="text-2xl font-semibold">Bienvenue {{ user.fullName }}</h2>
        <p class="text-sm text-slate-600">Console opérateur pour la relation client, les connecteurs tiers et le support accès.</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <section class="bg-white border border-slate-200 rounded-lg p-4">
            <h3 class="font-semibold mb-2">Dossiers clients actifs</h3>
            <p class="text-3xl font-semibold">{{ notes_count }}</p>
            <p class="text-xs text-slate-500 mt-2">Informations réglementaires et identifiants métier.</p>
        </section>

        <section class="bg-white border border-slate-200 rounded-lg p-4">
            <h3 class="font-semibold mb-2">Connecteurs configurés</h3>
            <p class="text-3xl font-semibold">{{ secrets_count }}</p>
            <p class="text-xs text-slate-500 mt-2">Clés API fictives pour partenaires externes.</p>
        </section>

        <section class="bg-white border border-slate-200 rounded-lg p-4">
            <h3 class="font-semibold mb-2">Parcours opérateur</h3>
            <ul class="text-sm text-slate-700 space-y-2">
                <li><a class="text-blue-600 hover:underline" href="{{ path('register_form') }}">Onboarding opérateur</a></li>
                <li><a class="text-blue-600 hover:underline" href="{{ path('forgot_password') }}">Traitement d'une perte d'accès</a></li>
                <li><a class="text-blue-600 hover:underline" href="{{ path('challenges_index') }}">Guide formation sécurité</a></li>
            </ul>
        </section>
    </div>
</div>
{% endblock %}
