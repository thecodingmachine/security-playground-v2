{% extends 'base.html.twig' %}

{% block title %}Validation lien récupération{% endblock %}

{% block body %}
<div class="bg-white border border-slate-200 rounded-lg p-6 max-w-xl space-y-4">
    <h2 class="text-xl font-semibold">Validation du lien de récupération</h2>
    <p class="text-sm text-slate-600">Compte ciblé : {{ token.user.username }}</p>
    <p class="text-sm text-slate-600">Token reçu : <code>{{ token.token }}</code></p>
    <form method="post" class="space-y-3">
        <p class="text-sm text-slate-600">Ce bouton simule l'ouverture de session sur ce compte via le token présenté.</p>
        <button type="submit" class="rounded bg-slate-900 text-white px-4 py-2 text-sm">Valider le lien</button>
    </form>

    {% if session_user is defined %}
        <div class="rounded border border-emerald-300 bg-emerald-50 text-emerald-700 px-3 py-2 text-sm">
            Session applicative simulée ouverte pour <strong>{{ session_user.username }}</strong>.
        </div>
    {% endif %}
</div>
{% endblock %}
