{% extends 'base.html.twig' %}

{% block title %}Réinitialisation{% endblock %}

{% block body %}
<div class="space-y-6">
    <section class="bg-white border border-slate-200 rounded-lg p-6">
        <h2 class="text-xl font-semibold mb-1">Support perte d'accès</h2>
        <p class="text-sm text-slate-600 mb-4">Workflow interne de génération de lien de récupération pour un opérateur.</p>
        <form method="post" action="{{ path('forgot_password_submit') }}" class="flex items-end gap-3">
            <div>
                <label for="username" class="block text-sm font-medium mb-1">Utilisateur</label>
                <input id="username" name="username" type="text" required class="rounded border border-slate-300 px-3 py-2 text-sm">
            </div>
            <button type="submit" class="rounded bg-slate-900 text-white px-4 py-2 text-sm">Créer un lien de récupération</button>
        </form>
    </section>

    {% if issued_token is defined %}
        <section class="bg-white border border-slate-200 rounded-lg p-6 space-y-3">
            <h3 class="font-semibold">Lien simulé envoyé au collaborateur</h3>
            <p class="text-sm text-slate-700">Compte : <strong>{{ issued_user.username }}</strong></p>
            <p class="text-sm text-slate-700">Token : <code>{{ issued_token }}</code></p>
            <p class="text-sm">
                URL locale :
                <a class="text-blue-600 hover:underline" href="{{ path('reset_password', {token: issued_token}) }}">
                    {{ path('reset_password', {token: issued_token}) }}
                </a>
            </p>
        </section>

        <section class="bg-white border border-slate-200 rounded-lg p-6">
            <h3 class="font-semibold mb-2">Historique des derniers tokens</h3>
            <ul class="text-sm space-y-2">
                {% for token in recent_tokens %}
                    <li class="border border-slate-100 rounded px-3 py-2">
                        <div><strong>{{ token.token }}</strong></div>
                        <div class="text-xs text-slate-500">{{ token.createdAt|date('d/m/Y H:i:s') }}</div>
                    </li>
                {% endfor %}
            </ul>
        </section>
    {% endif %}
</div>
{% endblock %}
