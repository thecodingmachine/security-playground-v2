{% extends 'base.html.twig' %}

{% block title %}Dump mots de passe{% endblock %}

{% block body %}
<div class="space-y-6">
    <section class="bg-white border border-slate-200 rounded-lg p-6">
        <h2 class="text-xl font-semibold mb-1">Export audit identités</h2>
        <p class="text-sm text-slate-600 mb-4">Extrait d'un export interne utilisé pendant une revue de conformité.</p>
        <table class="w-full text-sm">
            <thead>
            <tr class="text-left border-b">
                <th class="py-2">Identifiant</th>
                <th class="py-2">Utilisateur</th>
                <th class="py-2">Hash stocké</th>
            </tr>
            </thead>
            <tbody>
            {% for user in users %}
                <tr class="border-b border-slate-100">
                    <td class="py-2">{{ user.id }}</td>
                    <td class="py-2">{{ user.username }}</td>
                    <td class="py-2"><code>{{ user.password }}</code></td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </section>

    <section class="bg-white border border-slate-200 rounded-lg p-6">
        <h3 class="font-semibold mb-3">Référentiel de mots de passe faibles</h3>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-2 text-sm">
            {% for password in dictionary %}
                <div class="rounded border border-slate-200 px-3 py-2">{{ password }}</div>
            {% endfor %}
        </div>
    </section>

    <section class="bg-white border border-slate-200 rounded-lg p-6 space-y-4">
        <div>
            <h3 class="font-semibold mb-1">Atelier pédagogique : test dictionnaire MD5</h3>
            <p class="text-sm text-slate-600">Choisissez un compte et un mot de passe candidat pour vérifier si le hash MD5 correspond.</p>
        </div>

        <form method="get" action="{{ path('lab_password_dump') }}" class="grid grid-cols-1 md:grid-cols-3 gap-3 items-end">
            <div>
                <label for="user_id" class="block text-sm font-medium mb-1">Compte cible</label>
                <select id="user_id" name="user_id" class="w-full rounded border border-slate-300 px-3 py-2 text-sm" required>
                    <option value="">Sélectionner un utilisateur</option>
                    {% for user in users %}
                        <option value="{{ user.id }}" {{ selected_user_id == user.id ? 'selected' : '' }}>
                            {{ user.username }} ({{ user.password }})
                        </option>
                    {% endfor %}
                </select>
            </div>
            <div>
                <label for="candidate_password" class="block text-sm font-medium mb-1">Mot de passe candidat</label>
                <input
                    id="candidate_password"
                    name="candidate_password"
                    type="text"
                    value="{{ candidate_password }}"
                    class="w-full rounded border border-slate-300 px-3 py-2 text-sm"
                    placeholder="Ex: password"
                    required
                >
            </div>
            <button type="submit" class="rounded bg-slate-900 text-white px-4 py-2 text-sm w-fit">Tester la correspondance</button>
        </form>

        {% if comparison is not null %}
            <div class="rounded border p-4 text-sm {{ comparison.match ? 'border-emerald-300 bg-emerald-50 text-emerald-800' : 'border-amber-300 bg-amber-50 text-amber-900' }}">
                <p><strong>Utilisateur :</strong> {{ comparison.user.username }}</p>
                <p><strong>Candidat :</strong> <code>{{ comparison.candidate_password }}</code></p>
                <p><strong>MD5(candidat) :</strong> <code>{{ comparison.candidate_hash }}</code></p>
                <p><strong>Hash stocké :</strong> <code>{{ comparison.stored_hash }}</code></p>
                <p class="mt-2 font-semibold">
                    {{ comparison.match ? 'MATCH: le mot de passe candidat est correct.' : 'NO MATCH: le mot de passe candidat est incorrect.' }}
                </p>
            </div>
        {% endif %}
    </section>
</div>
{% endblock %}
