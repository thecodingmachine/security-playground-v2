{% extends 'base.html.twig' %}

{% block title %}Dump mots de passe{% endblock %}

{% block body %}
<div class="space-y-6">
    <section class="bg-white border border-slate-200 rounded-lg p-6">
        <h2 class="text-xl font-semibold mb-1">Export audit identités</h2>
        <p class="text-sm text-slate-600 mb-4">Extrait d'un export interne utilisé pendant une revue de conformité.</p>
        <table class="w-full text-sm">
            <thead>
            <tr class="text-left border-b">
                <th class="py-2">Identifiant</th>
                <th class="py-2">Utilisateur</th>
                <th class="py-2">Hash stocké</th>
            </tr>
            </thead>
            <tbody>
            {% for user in users %}
                <tr class="border-b border-slate-100">
                    <td class="py-2">{{ user.id }}</td>
                    <td class="py-2">{{ user.username }}</td>
                    <td class="py-2"><code>{{ user.password }}</code></td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </section>

    <section class="bg-white border border-slate-200 rounded-lg p-6">
        <h3 class="font-semibold mb-3">Référentiel de mots de passe faibles</h3>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-2 text-sm">
            {% for password in dictionary %}
                <div class="rounded border border-slate-200 px-3 py-2">{{ password }}</div>
            {% endfor %}
        </div>
    </section>
</div>
{% endblock %}
