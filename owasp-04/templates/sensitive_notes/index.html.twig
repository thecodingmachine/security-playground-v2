{% extends 'base.html.twig' %}

{% block title %}Notes sensibles{% endblock %}

{% block body %}
<div class="space-y-6">
    <section class="bg-white border border-slate-200 rounded-lg p-6">
        <h2 class="text-xl font-semibold mb-1">Dossier client confidentiel</h2>
        <p class="text-sm text-slate-600 mb-4">Enregistrer une information réglementaire pour un client entreprise.</p>
        <form method="post" action="{{ path('sensitive_note_store') }}" class="grid grid-cols-1 md:grid-cols-3 gap-3">
            <input name="title" type="text" required placeholder="Type de donnée (fiscale, bancaire, interne)" class="rounded border border-slate-300 px-3 py-2 text-sm">
            <input name="value" type="text" required placeholder="Valeur confidentielle fictive" class="rounded border border-slate-300 px-3 py-2 text-sm md:col-span-2">
            <button type="submit" class="rounded bg-slate-900 text-white px-4 py-2 text-sm w-fit">Ajouter au dossier</button>
        </form>
    </section>

    <section class="bg-white border border-slate-200 rounded-lg p-6">
        <h3 class="font-semibold mb-3">Historique des dossiers</h3>
        <table class="w-full text-sm">
            <thead>
            <tr class="text-left border-b">
                <th class="py-2">Titre</th>
                <th class="py-2">Créée le</th>
                <th class="py-2 text-right"></th>
            </tr>
            </thead>
            <tbody>
            {% for note in notes %}
                <tr class="border-b border-slate-100">
                    <td class="py-2">{{ note.title }}</td>
                    <td class="py-2">{{ note.createdAt|date('d/m/Y H:i') }}</td>
                    <td class="py-2 text-right">
                        <a href="{{ path('sensitive_note_show', {id: note.id}) }}" class="text-blue-600 hover:underline">Voir détail</a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="3" class="py-3 text-slate-500">Aucune note.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </section>
</div>
{% endblock %}
