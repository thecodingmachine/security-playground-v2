{% extends 'base.html.twig' %}

{% block title %}Détail rapport{% endblock %}

{% block body %}
<article class="bg-white border border-slate-200 rounded-lg p-6 space-y-3">
    <h2 class="text-xl font-semibold">{{ report.title }}</h2>
    <p class="text-sm text-slate-500">{{ report.createdAt|date('d/m/Y H:i') }}</p>
    <p class="text-sm leading-relaxed">{{ report.content }}</p>
</article>
{% endblock %}
