{% extends 'base.html.twig' %}

{% block title %}Rapports{% endblock %}

{% block body %}
<div class="bg-white border border-slate-200 rounded-lg p-6">
    <h2 class="text-xl font-semibold mb-1">Rapports</h2>
    <p class="text-sm text-slate-600 mb-4">Consultez les derniers exports de supervision.</p>

    <table class="w-full text-sm">
        <thead>
        <tr class="text-left border-b">
            <th class="py-2">Titre</th>
            <th class="py-2">Date</th>
            <th class="py-2"></th>
        </tr>
        </thead>
        <tbody>
        {% for report in reports %}
            <tr class="border-b border-slate-100">
                <td class="py-2">{{ report.title }}</td>
                <td class="py-2">{{ report.createdAt|date('d/m/Y H:i') }}</td>
                <td class="py-2 text-right">
                    <a href="{{ path('reports_show', {id: report.id}) }}" class="text-blue-600 hover:underline">Voir</a>
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <form method="post" action="{{ path('reports_open') }}" class="mt-4 flex items-end gap-2">
        <div>
            <label for="report_id" class="block text-xs text-slate-500 mb-1">Ouvrir un rapport par identifiant</label>
            <input id="report_id" name="report_id" type="number" min="1" class="rounded border border-slate-300 px-3 py-2 text-sm">
        </div>
        <button type="submit" class="rounded bg-slate-900 text-white px-3 py-2 text-sm">Ouvrir</button>
    </form>
</div>
{% endblock %}
