{% extends 'base.html.twig' %}

{% block title %}Commandes{% endblock %}

{% block body %}
<div class="space-y-6">
    <div class="bg-white border border-slate-200 rounded-lg p-5">
        <h2 class="text-2xl font-semibold">Commandes clients</h2>
        <p class="text-sm text-slate-600 mt-1">Historique des commandes liées à votre compte.</p>
    </div>

    <section class="bg-white border border-slate-200 rounded-lg p-5 overflow-x-auto">
        <table class="w-full text-sm">
            <thead>
            <tr class="text-left border-b border-slate-200 text-slate-500">
                <th class="py-2 pr-4">Référence</th>
                <th class="py-2 pr-4">Statut</th>
                <th class="py-2 pr-4">Montant</th>
                <th class="py-2 pr-4">Paiement</th>
                <th class="py-2 pr-4">Action</th>
            </tr>
            </thead>
            <tbody>
            {% for order in orders %}
                <tr class="border-b border-slate-100">
                    <td class="py-2 pr-4 font-medium">{{ order.reference }}</td>
                    <td class="py-2 pr-4">{{ order.status }}</td>
                    <td class="py-2 pr-4">{{ (order.amountCents / 100)|number_format(2, ',', ' ') }} {{ order.currency }}</td>
                    <td class="py-2 pr-4">
                        <a class="text-slate-700 hover:underline" href="{{ path('checkout_show', {id: order.id}) }}">Accéder au checkout</a>
                    </td>
                    <td class="py-2 pr-4">
                        <a class="text-slate-700 hover:underline" href="{{ path('orders_show', {id: order.id}) }}">Voir détail</a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="5" class="py-3 text-slate-500">Aucune commande.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </section>
</div>
{% endblock %}

