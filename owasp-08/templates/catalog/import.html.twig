{% extends 'base.html.twig' %}

{% block title %}Import catalogue{% endblock %}

{% block body %}
<div class="space-y-6">
    <section class="bg-white border border-slate-200 rounded-lg p-5">
        <h2 class="text-xl font-semibold">Import catalogue produits</h2>
        <p class="text-sm text-slate-600 mt-1">Chargez un fichier JSON ou CSV, contrôlez l'aperçu puis appliquez les changements.</p>

        {% for message in app.flashes('success') %}
            <p class="mt-3 rounded border border-emerald-300 bg-emerald-50 px-3 py-2 text-sm text-emerald-800">{{ message }}</p>
        {% endfor %}

        <form method="post" enctype="multipart/form-data" class="mt-4 flex flex-wrap items-end gap-3 text-sm">
            <input type="hidden" name="action" value="preview">
            <div>
                <label class="block text-slate-600 mb-1" for="catalog_file">Fichier import</label>
                <input id="catalog_file" name="catalog_file" type="file" accept=".json,.csv" class="rounded border border-slate-300 px-3 py-2">
            </div>
            <button type="submit" class="rounded bg-slate-900 px-4 py-2 text-white">Générer aperçu</button>
        </form>
    </section>

    {% if preview_rows is not empty %}
        <section class="bg-white border border-slate-200 rounded-lg p-5">
            <h3 class="font-semibold">Aperçu avant application</h3>
            <p class="text-sm text-slate-600 mt-1">Fichier: {{ preview_filename }} · checksum: <span class="font-mono">{{ preview_checksum }}</span></p>

            <div class="mt-4 overflow-x-auto">
                <table class="w-full text-xs">
                    <thead>
                    <tr class="border-b border-slate-200 text-left text-slate-500">
                        <th class="py-2 pr-3">sku</th>
                        <th class="py-2 pr-3">name</th>
                        <th class="py-2 pr-3">price_cents</th>
                        <th class="py-2 pr-3">discount_percent</th>
                        <th class="py-2 pr-3">is_public</th>
                        <th class="py-2 pr-3">is_featured</th>
                        <th class="py-2 pr-3">status</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for row in preview_rows %}
                        <tr class="border-b border-slate-100">
                            <td class="py-2 pr-3 font-mono">{{ row.sku ?? '' }}</td>
                            <td class="py-2 pr-3">{{ row.name ?? '' }}</td>
                            <td class="py-2 pr-3">{{ row.price_cents ?? '' }}</td>
                            <td class="py-2 pr-3">{{ row.discount_percent ?? '' }}</td>
                            <td class="py-2 pr-3">{{ row.is_public ?? '' }}</td>
                            <td class="py-2 pr-3">{{ row.is_featured ?? '' }}</td>
                            <td class="py-2 pr-3">{{ row.status ?? '' }}</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>

            <form method="post" class="mt-4">
                <input type="hidden" name="action" value="apply">
                <input type="hidden" name="import_filename" value="{{ preview_filename }}">
                <input type="hidden" name="import_checksum" value="{{ preview_checksum }}">
                <textarea name="import_payload" class="hidden">{{ preview_rows|json_encode }}</textarea>
                <button type="submit" class="rounded bg-slate-900 px-4 py-2 text-sm text-white">Appliquer les changements</button>
            </form>
        </section>
    {% endif %}

    <section class="bg-white border border-slate-200 rounded-lg p-5">
        <h3 class="font-semibold">Catalogue actuel</h3>
        <div class="mt-4 overflow-x-auto">
            <table class="w-full text-xs">
                <thead>
                <tr class="border-b border-slate-200 text-left text-slate-500">
                    <th class="py-2 pr-3">sku</th>
                    <th class="py-2 pr-3">name</th>
                    <th class="py-2 pr-3">price_cents</th>
                    <th class="py-2 pr-3">discount_percent</th>
                    <th class="py-2 pr-3">is_public</th>
                    <th class="py-2 pr-3">is_featured</th>
                    <th class="py-2 pr-3">status</th>
                </tr>
                </thead>
                <tbody>
                {% for product in products %}
                    <tr class="border-b border-slate-100">
                        <td class="py-2 pr-3 font-mono">{{ product.sku }}</td>
                        <td class="py-2 pr-3">{{ product.name }}</td>
                        <td class="py-2 pr-3">{{ product.priceCents }}</td>
                        <td class="py-2 pr-3">{{ product.discountPercent }}</td>
                        <td class="py-2 pr-3">{{ product.public ? 'true' : 'false' }}</td>
                        <td class="py-2 pr-3">{{ product.featured ? 'true' : 'false' }}</td>
                        <td class="py-2 pr-3">{{ product.status }}</td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="7" class="py-3 text-slate-500">Aucun produit.</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </section>

    <section class="bg-white border border-slate-200 rounded-lg p-5">
        <h3 class="font-semibold">Historique des imports</h3>
        <div class="mt-4 overflow-x-auto">
            <table class="w-full text-xs">
                <thead>
                <tr class="border-b border-slate-200 text-left text-slate-500">
                    <th class="py-2 pr-3">Date</th>
                    <th class="py-2 pr-3">Utilisateur</th>
                    <th class="py-2 pr-3">Fichier</th>
                    <th class="py-2 pr-3">Lignes</th>
                    <th class="py-2 pr-3">Checksum</th>
                </tr>
                </thead>
                <tbody>
                {% for import in imports %}
                    <tr class="border-b border-slate-100">
                        <td class="py-2 pr-3">{{ import.createdAt|date('Y-m-d H:i') }}</td>
                        <td class="py-2 pr-3">{{ import.importedBy.username }}</td>
                        <td class="py-2 pr-3">{{ import.filename }}</td>
                        <td class="py-2 pr-3">{{ import.rowCount }}</td>
                        <td class="py-2 pr-3 font-mono">{{ import.checksum }}</td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="py-3 text-slate-500">Aucun import enregistré.</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </section>
</div>
{% endblock %}

