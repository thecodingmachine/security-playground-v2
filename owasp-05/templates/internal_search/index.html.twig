{% extends 'base.html.twig' %}

{% block title %}Recherche interne{% endblock %}

{% block body %}
<div class="space-y-6">
    <div class="bg-white border border-slate-200 rounded-lg p-5">
        <h2 class="text-2xl font-semibold">Recherche globale interne</h2>
        <p class="text-sm text-slate-600 mt-1">Utilisée par l'équipe support pour retrouver rapidement des ressources.</p>
    </div>

    <form method="get" class="bg-white border border-slate-200 rounded-lg p-5 space-y-3">
        <label for="q" class="text-sm font-medium">Recherche interne</label>
        <div class="flex gap-2">
            <input id="q" name="q" value="{{ query }}" class="flex-1 rounded border border-slate-300 px-3 py-2 text-sm" placeholder="Nom de produit ou mot-clé">
            <button type="submit" class="rounded bg-slate-900 text-white px-4 py-2 text-sm">Analyser</button>
        </div>
    </form>

    <section class="bg-white border border-slate-200 rounded-lg overflow-hidden">
        <table class="w-full text-sm">
            <thead class="bg-slate-50 text-left">
            <tr>
                <th class="px-4 py-3">ID</th>
                <th class="px-4 py-3">Nom</th>
                <th class="px-4 py-3">Type</th>
            </tr>
            </thead>
            <tbody>
            {% for row in results %}
                <tr class="border-t border-slate-200">
                    <td class="px-4 py-3">{{ row.id }}</td>
                    <td class="px-4 py-3">{{ row.name }}</td>
                    <td class="px-4 py-3 uppercase text-xs text-slate-600">{{ row.type }}</td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="3" class="px-4 py-6 text-center text-slate-500">Aucun résultat.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </section>
</div>
{% endblock %}
