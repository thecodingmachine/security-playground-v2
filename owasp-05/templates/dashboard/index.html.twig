{% extends 'base.html.twig' %}

{% block title %}Tableau de bord{% endblock %}

{% block body %}
<div class="space-y-6">
    <div class="bg-white border border-slate-200 rounded-lg p-5">
        <h2 class="text-2xl font-semibold">Tableau de bord commercial</h2>
        <p class="text-sm text-slate-600 mt-1">Bienvenue {{ current_user.fullName }}. Suivez les indicateurs de votre équipe.</p>
    </div>

    <form method="get" class="bg-white border border-slate-200 rounded-lg p-5 space-y-3">
        <label for="filter" class="text-sm font-medium">Filtre de recherche enregistré</label>
        <div class="flex gap-2">
            <input id="filter" name="filter" value="{{ filter }}" class="flex-1 rounded border border-slate-300 px-3 py-2 text-sm" placeholder="Ex: ventes Europe">
            <button type="submit" class="rounded bg-slate-900 text-white px-4 py-2 text-sm">Appliquer</button>
        </div>
        <p class="text-xs text-slate-500">Ce filtre est repris par le script de personnalisation du tableau de bord.</p>
    </form>

    <div class="grid md:grid-cols-3 gap-4">
        {% for item in sales %}
            <article class="bg-white border border-slate-200 rounded-lg p-4">
                <p class="text-sm text-slate-600">{{ item.label }}</p>
                <p class="text-xl font-semibold mt-1">{{ item.value }}</p>
            </article>
        {% endfor %}
    </div>
</div>

<script>
    window.currentFilter = "{{ filter|raw }}";
</script>
{% endblock %}
