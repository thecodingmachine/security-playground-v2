{% extends 'base.html.twig' %}

{% block title %}Utilisateurs back-office{% endblock %}

{% block body %}
<div class="space-y-6">
    <div class="bg-white border border-slate-200 rounded-lg p-5">
        <h2 class="text-2xl font-semibold">Utilisateurs back-office</h2>
        <p class="text-sm text-slate-600 mt-1">Mode {{ mode == 'vulnerable' ? 'administration standard' : 'administration sécurisée' }}.</p>
    </div>

    <section class="bg-white border border-slate-200 rounded-lg overflow-hidden">
        <table class="min-w-full text-sm">
            <thead class="bg-slate-50">
            <tr>
                <th class="text-left px-4 py-3 font-medium">ID</th>
                <th class="text-left px-4 py-3 font-medium">Utilisateur</th>
                <th class="text-left px-4 py-3 font-medium">Nom complet</th>
                <th class="text-left px-4 py-3 font-medium">Rôles</th>
            </tr>
            </thead>
            <tbody>
            {% for user in users %}
                <tr class="border-t border-slate-100">
                    <td class="px-4 py-3">{{ user.id }}</td>
                    <td class="px-4 py-3">{{ user.username }}</td>
                    <td class="px-4 py-3">{{ user.fullName }}</td>
                    <td class="px-4 py-3">{{ user.roles|join(', ') }}</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </section>
</div>
{% endblock %}
