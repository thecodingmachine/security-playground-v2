{% extends 'base.html.twig' %}

{% block title %}Export finance{% endblock %}

{% block body %}
<div class="space-y-6">
    <div class="bg-white border border-slate-200 rounded-lg p-5">
        <h2 class="text-2xl font-semibold">Export finance sensible</h2>
        <p class="text-sm text-slate-600 mt-1">Cette extraction regroupe des rapports internes sensibles.</p>
    </div>

    <section class="bg-white border border-slate-200 rounded-lg p-5 space-y-4">
        <p class="text-sm text-slate-700">Utilisez l'option de simulation pour tester un incident technique sur la vérification de permission.</p>
        <form method="get" action="{{ path(route_name) }}" class="space-y-3">
            <input type="hidden" name="download" value="1">
            <label class="flex items-center gap-2 text-sm">
                <input type="checkbox" name="simulate_failure" value="1" class="rounded border-slate-300">
                Simuler une panne du service de permission
            </label>
            <button class="rounded bg-slate-900 text-white px-4 py-2 text-sm" type="submit">Lancer l'export</button>
        </form>
    </section>
</div>
{% endblock %}
