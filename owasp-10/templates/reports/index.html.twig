{% extends 'base.html.twig' %}

{% block title %}Rapports{% endblock %}

{% block body %}
<div class="space-y-6">
    <div class="bg-white border border-slate-200 rounded-lg p-5">
        <h2 class="text-2xl font-semibold">Rapports opérationnels</h2>
        <p class="text-sm text-slate-600 mt-1">Exportez un rapport individuel pour audit ou partage interne.</p>
    </div>

    <section class="bg-white border border-slate-200 rounded-lg overflow-hidden">
        <table class="min-w-full text-sm">
            <thead class="bg-slate-50">
            <tr>
                <th class="text-left px-4 py-3 font-medium">ID</th>
                <th class="text-left px-4 py-3 font-medium">Titre</th>
                <th class="text-left px-4 py-3 font-medium">Sensibilité</th>
                <th class="text-left px-4 py-3 font-medium">Action</th>
            </tr>
            </thead>
            <tbody>
            {% for report in reports %}
                <tr class="border-t border-slate-100">
                    <td class="px-4 py-3">{{ report.id }}</td>
                    <td class="px-4 py-3">{{ report.title }}</td>
                    <td class="px-4 py-3">{{ report.isSensitive ? 'sensible' : 'standard' }}</td>
                    <td class="px-4 py-3">
                        <a class="rounded bg-slate-900 text-white px-3 py-1.5 text-xs" href="{{ path('reports_export', {id: report.id}) }}">Exporter</a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="4" class="px-4 py-4 text-slate-500">Aucun rapport.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </section>
</div>
{% endblock %}
